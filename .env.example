# Copy to backend/.env for local dev, or to .env at repo root for docker compose.

# --- required in production ---
JWT_SECRET=change-me-to-a-long-random-string-32-bytes-minimum

# --- optional: enables the AI agents (research, strategy builder, briefings) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- optional: enables the Alpaca paper broker + Alpaca market data ---
# Get free paper keys at https://app.alpaca.markets (paper trading section).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- optional overrides ---
# DATABASE_URL=postgresql+psycopg2://pvt:pvt@localhost:5432/pvt   (default: sqlite file)
# MARKET_DATA_PROVIDER=yfinance   # yfinance | alpaca
# QUOTE_REFRESH_SECONDS=60
